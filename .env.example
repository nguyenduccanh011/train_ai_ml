# Stock ML Platform - Environment Configuration
# Copy to .env and update values

# ============================================
# Application
# ============================================
APP_NAME=Stock ML Platform
APP_VERSION=1.0.0
DEBUG=False

# ============================================
# Server
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=9001      # Changed from 3000 (Windows blocks port 3000)
NGINX_PORT=80            # Reverse proxy listens on 80, forwards to 8000 (API) and 9001 (dashboard)

# ============================================
# Paths
# ============================================
DATA_DIR=./data
RESULTS_DIR=./results
CONFIG_DIR=./stock_ml/config
LOG_DIR=./logs
LOG_FILE=./logs/app.log

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# Database (PostgreSQL)
# ============================================
# Local development: postgresql+asyncpg://stockml:stockml_dev@localhost:5432/stockml
# Docker: use 'postgres' as hostname (Docker service name)
DATABASE_URL=postgresql+asyncpg://stockml:stockml_dev@postgres:5432/stockml
DB_ENABLED=true
# Set POSTGRES_PASSWORD environment variable for Docker
# For local dev without Docker: set to localhost and DB_ENABLED=false
POSTGRES_PASSWORD=stockml_dev

# ============================================
# CORS
# ============================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ============================================
# Security (Production Only)
# ============================================
# API_KEY=your_secret_key_here
# JWT_SECRET=your_jwt_secret_here
# ALLOWED_HOSTS=["api.example.com"]

# ============================================
# External Services
# ============================================
# REDIS_URL=redis://localhost:6379
# CELERY_BROKER_URL=redis://localhost:6379
# MONITORING_WEBHOOK=https://monitoring.example.com/webhook

# ============================================
# Feature Flags
# ============================================
ENABLE_ASYNC_TRAINING=False
ENABLE_LIVE_TRADING=False
ENABLE_LEADERBOARD=True
